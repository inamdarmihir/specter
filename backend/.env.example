# ── Specter backend environment — copy to .env and fill in values ─────────────

# Required: OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-...

# Optional: model overrides (defaults shown)
# SPECTER_MODEL=openai:gpt-4o-mini
# SPECTER_EMBED_MODEL=openai:text-embedding-3-small
# SPECTER_TEMPERATURE=0.2

# Qdrant vector store
# Use :memory: for local in-process store (no Docker needed, data lost on restart)
# Use http://localhost:6333 when running a real Qdrant server (docker run -p 6333:6333 qdrant/qdrant)
QDRANT_URL=:memory:
# QDRANT_API_KEY=          # only needed for Qdrant Cloud
# QDRANT_COLLECTION=specter_memory

# Server bind (defaults shown)
# HOST=0.0.0.0
# PORT=8000
# DEV=1                    # enables uvicorn --reload

# Browser automation via agent-browser (https://github.com/vercel-labs/agent-browser)
# Set to true to give Specter web browsing tools (open pages, click, fill, screenshot, read)
# Setup: npm install -g agent-browser && agent-browser install
# AGENT_BROWSER_ENABLED=true
